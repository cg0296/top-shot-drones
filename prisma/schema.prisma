generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
  VIEWER
}

enum VideoVisibility {
  PUBLIC
  ORG
  PRIVATE
}

enum AccessType {
  VIEW
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String        @map("password_hash")
  role            Role          @default(CUSTOMER)
  organizationId  String?       @map("organization_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  sessions        Session[]
  videoAccess     VideoAccess[]
  uploadedVideos  Video[]       @relation("UploadedBy")

  @@map("users")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  videos    Video[]

  @@map("organizations")
}

model Video {
  id                 String          @id @default(cuid())
  title              String
  description        String?
  cloudflareVideoId  String          @unique @map("cloudflare_video_id")
  thumbnailUrl       String?         @map("thumbnail_url")
  organizationId     String          @map("organization_id")
  uploadedByUserId   String          @map("uploaded_by_user_id")
  visibility         VideoVisibility @default(ORG)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy         User            @relation("UploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  videoAccess        VideoAccess[]

  @@map("videos")
}

model VideoAccess {
  id         String     @id @default(cuid())
  videoId    String     @map("video_id")
  userId     String     @map("user_id")
  accessType AccessType @default(VIEW) @map("access_type")
  createdAt  DateTime   @default(now()) @map("created_at")

  video      Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@map("video_access")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}
