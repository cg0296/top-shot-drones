generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
  VIEWER
}

enum VideoVisibility {
  PUBLIC
  ORG
  PRIVATE
}

enum AccessType {
  VIEW
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String        @map("password_hash")
  role            Role          @default(CUSTOMER)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  memberships     OrganizationMembership[]
  sessions        Session[]
  videoAccess     VideoAccess[]
  uploadedVideos  Video[]       @relation("UploadedBy")
  comments        Comment[]
  reactions       Reaction[]
  auditLogs       AuditLog[]
  purchases       Purchase[]

  @@map("users")
}

model OrganizationMembership {
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           Role     @default(CUSTOMER)
  isDefault      Boolean  @default(false) @map("is_default")
  joinedAt       DateTime @default(now()) @map("joined_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@index([organizationId])
  @@map("organization_memberships")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships      OrganizationMembership[]
  leagueMemberships LeagueMembership[]
  videos           Video[]
  seasons          Season[]
  homeGames        Game[]   @relation("HomeGames")
  awayGames        Game[]   @relation("AwayGames")

  @@map("organizations")
}

model Season {
  id             String    @id @default(cuid())
  name           String
  slug           String
  organizationId String?   @map("organization_id")  // null for league-scoped seasons
  leagueId       String?   @map("league_id")         // set for league-scoped seasons
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  league         League?       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  games          Game[]
  purchases      Purchase[]

  @@unique([organizationId, slug])
  @@unique([leagueId, slug])
  @@map("seasons")
}

model Game {
  id          String   @id @default(cuid())
  seasonId    String   @map("season_id")
  homeTeamId  String   @map("home_team_id")
  awayTeamId  String?  @map("away_team_id")
  title       String
  playedAt    DateTime @map("played_at")
  slug        String
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeam    Organization @relation("HomeGames", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam    Organization? @relation("AwayGames", fields: [awayTeamId], references: [id], onDelete: SetNull)
  videos      Video[]

  @@unique([seasonId, slug])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("games")
}

model Video {
  id                 String          @id @default(cuid())
  title              String
  description        String?
  cloudflareVideoId  String          @unique @map("cloudflare_video_id")
  thumbnailUrl       String?         @map("thumbnail_url")
  organizationId     String          @map("organization_id")
  uploadedByUserId   String          @map("uploaded_by_user_id")
  visibility         VideoVisibility @default(ORG)
  gameId             String?         @map("game_id")
  kind               String?
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy         User            @relation("UploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  game               Game?           @relation(fields: [gameId], references: [id], onDelete: SetNull)
  videoAccess        VideoAccess[]
  comments           Comment[]
  reactions          Reaction[]
  purchases          Purchase[]

  @@map("videos")
}

model VideoAccess {
  id         String     @id @default(cuid())
  videoId    String     @map("video_id")
  userId     String     @map("user_id")
  accessType AccessType @default(VIEW) @map("access_type")
  createdAt  DateTime   @default(now()) @map("created_at")

  video      Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@map("video_access")
}

model Comment {
  id        String   @id @default(cuid())
  videoId   String   @map("video_id")
  userId    String   @map("user_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Reaction {
  id        String   @id @default(cuid())
  videoId   String   @map("video_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId, emoji])
  @@map("reactions")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String   @map("actor_id")
  action       String
  targetEntity String   @map("target_entity")
  targetId     String   @map("target_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor        User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// A league is a competition that groups teams together across seasons
model League {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memberships LeagueMembership[]
  seasons     Season[]

  @@map("leagues")
}

// Which teams (orgs) belong to a league
model LeagueMembership {
  id       String   @id @default(cuid())
  leagueId String   @map("league_id")
  orgId    String   @map("org_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  league   League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([leagueId, orgId])
  @@index([orgId])
  @@map("league_memberships")
}

// Tracks paid access to an individual video or a full season
model Purchase {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  videoId     String?        @map("video_id")   // set for per-video purchase
  seasonId    String?        @map("season_id")  // set for season pass
  status      PurchaseStatus @default(COMPLETED)
  amountCents Int?           @map("amount_cents")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  video       Video?         @relation(fields: [videoId], references: [id], onDelete: SetNull)
  season      Season?        @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  // Prevent duplicate purchases for the same video or season
  @@unique([userId, videoId])
  @@unique([userId, seasonId])
  @@index([userId])
  @@map("purchases")
}
